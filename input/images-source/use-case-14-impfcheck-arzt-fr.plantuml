@startuml
scale max 800 width
<style>
element {MinimumWidth 200}
</style>

|Médecin en interaction\navec le patient|
start
|#LightBlue|PIS|
:Le médecin met à jour\nles données vaccinales;
:Le médecin lance le\ncontrôle vaccinal;

|#AntiqueWhite|Contrôle vaccinal|
:Le contrôle vaccinal affiche\nle statut vaccinal;
:Le contrôle vaccinal affiche\nles recommandations vaccinales;

|Médecin en interaction\navec le patient|
:Le médecin discute des\nrecommandations avec le patient;
if (Le patient souhaite\nse faire vacciner) then (Oui)
  :Le médecin effectue\nla vaccination;
  |#LightBlue|PIS|
  :Le médecin documente\nla vaccination;
  |Médecin en interaction\navec le patient|
else (Non)
  |PIS|
  :Le médecin documente\nle motif du refus;
  |Médecin en interaction\navec le patient|
endif

stop

@enduml

